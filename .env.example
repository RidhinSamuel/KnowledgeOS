# KnowledgeOS Environment Variables

# App Config
PORT=8000
LOG_LEVEL=INFO
JWT_SECRET=supersecretchangeinproduction123!
JWT_REFRESH_SECRET=anothersecretchangeinproduction456!

# Database Connections
# (Use service names inside docker-compose)
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=knowledge_os
REDIS_URL=redis://valkey:6379
QDRANT_URL=http://qdrant:6333

# AI & LLM Settings
# Supported: 'gemini', 'openai', 'huggingface' (local/hub)
LLM_PROVIDER=huggingface
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
HUGGINGFACE_API_KEY=YOUR_HUGGINGFACE_API_KEY_HERE
LLAMAPARSE_API_KEY=YOUR_LLAMAPARSE_API_KEY_HERE

# Embedding Model (run locally on CPU inside the worker)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
